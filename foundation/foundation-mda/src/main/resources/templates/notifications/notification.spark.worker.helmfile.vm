#set($path = "/src/${pythonPipelineArtifactId}/resources/apps/")
#if(${pipelineImplementation} == "data-delivery-spark")
  #set($path = "/src/main/resources/apps/")
#end
  - name: ${pipelineArtifactId}
    namespace: ${namespace}
    chart: oci://ghcr.io/boozallen/aissemble-spark-application-chart
    version: {{ .Values.aissembleVersion }}
    <<: *teardownPipelines
    values:
      - ${parentArtifactId}/${pipelineArtifactId}${path}${pipelineArtifactId}-base-values.yaml
      {{ if eq .Environment.Name "default" }}
      - ${parentArtifactId}/${pipelineArtifactId}${path}${pipelineArtifactId}-dev-values.yaml
      {{- end }}
      {{ if eq .Environment.Name "ci" }}
      - ${parentArtifactId}/${pipelineArtifactId}${path}${pipelineArtifactId}-ci-values.yaml
      {{- end }}