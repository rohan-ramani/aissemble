    private Dataset<Row> validateWithRelationRecordSchema(Dataset<Row> dataset, String validationColumn, TriFunction<Dataset<Row>, String, Boolean, Dataset<Row>> validateDataFrame, String resultColumn, boolean required) {
        final String ID = "id";
        final String EXPANDED_COLUMN = "EXPANDED_COLUMN";
        final String AGGREGATED_RESULT_COLUMN = String.format("bool_and(%s)", resultColumn);
        final String RESULT_COLUMN = String.format("__VALIDATE_%s", validationColumn);

        // add a row id
        dataset = dataset.withColumn(ID, row_number().over(Window.orderBy(monotonically_increasing_id())));

        // flatten relation array record data for relation record validation
        Dataset<Row> validationDataset = dataset.select(validationColumn, ID)
                                                .withColumn(EXPANDED_COLUMN, explode(col(validationColumn))).drop(validationColumn);
        // validate the flatten dataset
        validationDataset = validateDataFrame.apply(validationDataset, EXPANDED_COLUMN + ".", false).drop(EXPANDED_COLUMN);
        // group the validation result with original dataset row id
        validationDataset = validationDataset.groupBy(ID).agg(bool_and(col(resultColumn)))
                            .withColumn(RESULT_COLUMN, col(AGGREGATED_RESULT_COLUMN));
        // cleanup
        validationDataset = validationDataset.drop(resultColumn, AGGREGATED_RESULT_COLUMN);
        dataset = dataset.join(validationDataset, ID, "outer").drop(ID);

        if (required) {
            dataset = dataset.withColumn(RESULT_COLUMN, when(col(RESULT_COLUMN).isNotNull().and(col(RESULT_COLUMN).equalTo(lit(true))), lit(true)).otherwise(lit(false)));
        } else {
            dataset = dataset.withColumn(RESULT_COLUMN, when(col(RESULT_COLUMN).isNull().or(col(RESULT_COLUMN).equalTo(lit(true))), lit(true)).otherwise(lit(false)));
        }

        return dataset;
    }
