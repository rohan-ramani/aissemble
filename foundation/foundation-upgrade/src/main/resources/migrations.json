[
  {
    "group": "version-specific",
    "type": "ordered",
    "migrations": [
      {
        "name": "data-encryption-removal-pom-migration",
        "implementation": "com.boozallen.aissemble.upgrade.migration.version_specific.DataEncryptionRemovalPomMigration",
        "fileSets": [
          {
            "includes": [
              "pom.xml"
            ]
          }
        ]
      },
      {
        "name": "data-encryption-removal-pyproject-migration",
        "implementation": "com.boozallen.aissemble.upgrade.migration.version_specific.DataEncryptionRemovalPyprojectMigration",
        "fileSets": [
          {
            "includes": [
              "pyproject.toml"
            ]
          }
        ]
      },
      {
        "name": "spark-provided-dependency-migration",
        "implementation": "com.boozallen.aissemble.upgrade.migration.version_specific.SparkProvidedDependenciesMigration",
        "fileSets": [
          {
            "includes": [
              "pom.xml"
            ]
          }
        ]
      },
      {
        "name": "helmfile-generation-migration",
        "implementation": "com.boozallen.aissemble.upgrade.migration.version_specific.HelmfileGenerationMigration",
        "fileSets": [
          {
            "includes": ["pom.xml"]
          }
        ]
      },
      {
        "name": "argocd-removal-migration",
        "implementation": "com.boozallen.aissemble.upgrade.migration.version_specific.ArgoCDRemovalMigration",
        "fileSets": [
          {
            "includes": [
              "*-deploy/**/templates/*.yaml"
            ]
          }
        ]
      }
    ]
  },
  {
    "group": "general-migrations",
    "type": "ordered",
    "migrations": [
      {
        "name": "upgrade-tiltfile-aissemble-version-migration",
        "implementation": "com.boozallen.aissemble.upgrade.migration.TiltfileMigration",
        "fileSets": [
          {
            "includes": ["Tiltfile"]
          }
        ]
      },
      {
        "name": "upgrade-v2-chart-files-aissemble-version-migration",
        "implementation": "com.boozallen.aissemble.upgrade.migration.HelmChartsV2Migration",
        "fileSets": [
          {
            "includes": ["**/apps/**/Chart.yaml"]
          }
        ]
      },
      {
        "name": "upgrade-v1-chart-files-aissemble-version-migration",
        "implementation": "com.boozallen.aissemble.upgrade.migration.HelmChartsV1Migration",
        "fileSets": [
          {
            "includes": [
              "**/spark-infrastructure/values.yaml",
              "**/jenkins/values.yaml",
              "**/metadata/values.yaml",
              "**/model-training-api/values.yaml",
              "**/pipeline-invocation-service/values.yaml"
            ]
          }
        ]
      },
      {
        "name": "helmfile-aissemble-version-migration",
        "implementation": "com.boozallen.aissemble.upgrade.migration.HelmFileVersionMigration",
        "fileSets": [
          {
            "includes": ["*-deploy/src/main/resources/values-*-helmfile.yaml"]
          }
        ]
      }
    ]
  }
]
